    "Something went wrong. Please try again.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حدث خطأ ما. يرجى المحاولة مرة أخرى."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Нещо се обърка. Моля, опитайте отново."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "কিছু ভুল হয়েছে। অনুগ্রহ করে আবার চেষ্টা করুন।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Alguna cosa ha anat malament. Torna-ho a provar."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Něco se pokazilo. Zkuste to prosím znovu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Noget gik galt. Prøv venligst igen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Etwas ist schiefgelaufen. Bitte versuche es erneut."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Κάτι πήγε στραβά. Παρακαλώ δοκιμάστε ξανά."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Something went wrong. Please try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Algo salió mal. Por favor, inténtalo de nuevo."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Midagi läks valesti. Palun proovi uuesti."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Jokin meni pieleen. Yritä uudelleen."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "May nangyaring mali. Pakisubukan muli."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une erreur est survenue. Veuillez réessayer."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "કંઈક ખોટું થયું. કૃપા કરીને ફરીથી પ્રયાસ કરો."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "משהו השתבש. אנא נסה שוב."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कुछ गलत हो गया। कृपया पुनः प्रयास करें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nešto je pošlo po krivu. Pokušajte ponovo."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Valami hiba történt. Kérjük, próbáld újra."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Terjadi kesalahan. Silakan coba lagi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Qualcosa è andato storto. Riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エラーが発生しました。もう一度お試しください。"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಏನೋ ತಪ್ಪಾಗಿದೆ. ದಯವಿಟ್ಟು ಮತ್ತೆ ಪ್ರಯತ್ನಿಸಿ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "문제가 발생했습니다. 다시 시도해 주세요."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Kažkas nutiko. Bandykite dar kartą."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaut kas nogāja greizi. Lūdzu, mēģiniet vēlreiz."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "എന്തോ തെറ്റ് സംഭവിച്ചു. ദയവായി വീണ്ടും ശ്രമിക്കുക."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "काहीतरी चुकीचे झाले. कृपया पुन्हा प्रयत्न करा."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Sesuatu telah berlaku. Sila cuba lagi."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Noe gikk galt. Vennligst prøv igjen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er ging iets mis. Probeer het opnieuw."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਕੁਝ ਗਲਤ ਹੋ ਗਿਆ। ਕਿਰਪਾ ਕਰਕੇ ਦੁਬਾਰਾ ਕੋਸ਼ਿਸ਼ ਕਰੋ।"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Coś poszło nie tak. Spróbuj ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Algo deu errado. Tente novamente."
          }
        },
        "pt-PT": {
