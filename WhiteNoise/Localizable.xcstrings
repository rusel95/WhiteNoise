    "Auto-renews every %@ unless cancelled at least 24h before the period ends. Billed to your Apple ID. Manage in Settings.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتجدد تلقائياً كل %@ ما لم يُلغَ قبل 24 ساعة على الأقل من نهاية الفترة. تُحسب على حساب Apple ID الخاص بك. إدارة في الإعدادات."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Автоматично подновяване всеки %@, освен ако не бъде отменено поне 24 часа преди края на периода. Таксува се чрез вашия Apple ID. Управление в Настройки."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "প্রতি %@ স্বয়ংক্রিয় পুনর্নবায়ন হয় যদি না পিরিয়ড শেষের কমপক্ষে 24 ঘণ্টা আগে বাতিল করা হয়। আপনার Apple ID-তে বিল করা হয়। সেটিংসে পরিচালনা করুন।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Es renova automàticament cada %@ tret que es cancel·li almenys 24h abans del final del període. Facturat al teu Apple ID. Gestiona a Configuració."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Automaticky se obnovuje každých %@, pokud není zrušeno alespoň 24 hodin před koncem období. Účtováno na váš Apple ID. Spravovat v Nastavení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Fornyes automatisk hver %@ medmindre det opsiges mindst 24 timer før periodens udløb. Faktureres til dit Apple ID. Administrer i Indstillinger."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verlängert sich automatisch alle %@, sofern nicht mindestens 24 Stunden vor Ablauf gekündigt wird. Wird über deine Apple-ID abgerechnet. Verwalte in den Einstellungen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτόματη ανανέωση κάθε %@ εκτός εάν ακυρωθεί τουλάχιστον 24 ώρες πριν τη λήξη. Χρέωση στο Apple ID σας. Διαχείριση στις Ρυθμίσεις."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Auto-renews every %@ unless cancelled at least 24h before the period ends. Billed to your Apple ID. Manage in Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se renueva automáticamente cada %@ a menos que se cancele al menos 24h antes del final del periodo. Se factura a tu Apple ID. Administrar en Ajustes."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Uueneb automaatselt iga %@ tagant, kui see tühistatakse vähemalt 24 tundi enne perioodi lõppu. Arveldamine teie Apple ID kaudu. Hallake seadetes."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Uusiutuu automaattisesti joka %@, ellei peruuteta vähintään 24 tuntia ennen jakson päättymistä. Laskutetaan Apple ID:ltäsi. Hallitse asetuksissa."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Awtomatikong nire-renew bawat %@ maliban kung kanselado nang hindi bababa sa 24 oras bago matapos ang panahon. Sinisingil sa iyong Apple ID. Pamahalaan sa Settings."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Renouvellement automatique tous les %@ sauf annulation au moins 24h avant la fin de la période. Facturé sur votre identifiant Apple. Gérer dans les Réglages."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "દરેક %@ ઓટો-રિન્યૂ થાય છે જ્યાં સુધી સમયગાળો સમાપ્ત થતા ઓછામાં ઓછા 24 કલાક પહેલાં રદ ન કરવામાં આવે. તમારા Apple ID પર બિલ કરવામાં આવે છે. સેટિંગ્સમાં મેનેજ કરો."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מתחדש אוטומטית כל %@ אלא אם מבוטל לפחות 24 שעות לפני סוף התקופה. מחויב ל-Apple ID שלך. נהל בהגדרות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रत्येक %@ स्वतः नवीनीकृत होता है जब तक कि अवधि समाप्त होने से कम से कम 24 घंटे पहले रद्द न किया जाए। आपकी Apple ID पर बिल किया जाता है। सेटिंग्स में प्रबंधित करें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatski se obnavlja svakih %@ osim ako se ne otkaže najmanje 24h prije kraja razdoblja. Naplaćuje se na vaš Apple ID. Upravljajte u Postavkama."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatikusan megújul minden %@, hacsak nem mondják le legalább 24 órával az időszak vége előtt. Az Apple ID-dre számlázva. Kezelés a Beállításokban."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Diperbarui otomatis setiap %@ kecuali dibatalkan setidaknya 24 jam sebelum periode berakhir. Ditagih ke Apple ID Anda. Kelola di Pengaturan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Si rinnova automaticamente ogni %@ se non annullato almeno 24h prima della fine del periodo. Addebitato sul tuo ID Apple. Gestisci nelle Impostazioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ごとに自動更新されます（期間終了の24時間前までにキャンセルしない場合）。Apple IDに請求されます。設定で管理。"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಪ್ರತಿ %@ ಸ್ವಯಂ-ನವೀಕರಣಗೊಳ್ಳುತ್ತದೆ, ಅವಧಿ ಮುಗಿಯುವ ಕನಿಷ್ಠ 24 ಗಂಟೆ ಮೊದಲು ರದ್ದುಪಡಿಸದಿದ್ದರೆ. ನಿಮ್ಮ Apple ID ಗೆ ಬಿಲ್ ಮಾಡಲಾಗುತ್ತದೆ. ಸೆಟ್ಟಿಂಗ್‌ಗಳಲ್ಲಿ ನಿರ್ವಹಿಸಿ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기간 종료 최소 24시간 전에 취소하지 않으면 %@마다 자동 갱신됩니다. Apple ID로 청구됩니다. 설정에서 관리하세요."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatiškai atnaujinama kas %@, nebent atšaukta bent 24 val. prieš laikotarpio pabaigą. Apmokestinama jūsų Apple ID. Tvarkykite nustatymuose."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Automātiski atjaunojas ik pēc %@, ja vien nav atcelts vismaz 24 stundas pirms perioda beigām. Maksājums tiek veikts no jūsu Apple ID. Pārvaldiet iestatījumos."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "ഓരോ %@ ഓട്ടോ-റിന്യൂ ചെയ്യുന്നു, കാലയളവ് അവസാനിക്കുന്നതിന് 24 മണിക്കൂർ മുമ്പെങ്കിലും റദ്ദാക്കിയില്ലെങ്കിൽ. നിങ്ങളുടെ Apple ID-യിൽ ബിൽ ചെയ്യുന്നു. സെറ്റിംഗ്സിൽ മാനേജ് ചെയ്യുക."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रत्येक %@ ऑटो-रिन्यू होतो जोपर्यंत कालावधी संपण्याच्या किमान 24 तास आधी रद्द केला जात नाही. तुमच्या Apple ID वर बिल केले जाते. सेटिंग्जमध्ये व्यवस्थापित करा."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Diperbaharui secara automatik setiap %@ melainkan dibatalkan sekurang-kurangnya 24 jam sebelum tempoh tamat. Dibilkan ke Apple ID anda. Urus di Tetapan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Fornyes automatisk hver %@ med mindre det kanselleres minst 24 timer før periodens slutt. Faktureres til din Apple-ID. Administrer i Innstillinger."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wordt automatisch verlengd elke %@ tenzij minimaal 24 uur voor het einde van de periode opgezegd. Gefactureerd op je Apple ID. Beheer in Instellingen."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਹਰ %@ ਆਟੋ-ਰੀਨਿਊ ਹੁੰਦਾ ਹੈ ਜਦੋਂ ਤੱਕ ਮਿਆਦ ਖਤਮ ਹੋਣ ਤੋਂ ਘੱਟੋ-ਘੱਟ 24 ਘੰਟੇ ਪਹਿਲਾਂ ਰੱਦ ਨਹੀਂ ਕੀਤਾ ਜਾਂਦਾ। ਤੁਹਾਡੀ Apple ID 'ਤੇ ਬਿੱਲ ਕੀਤਾ ਜਾਂਦਾ ਹੈ। ਸੈਟਿੰਗਾਂ ਵਿੱਚ ਪ੍ਰਬੰਧਿਤ ਕਰੋ।"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatycznie odnawia się co %@, chyba że zostanie anulowane co najmniej 24h przed końcem okresu. Rozliczane na Twoje Apple ID. Zarządzaj w Ustawieniach."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Renova automaticamente a cada %@ a menos que seja cancelado pelo menos 24h antes do fim do período. Cobrado no seu Apple ID. Gerencie nos Ajustes."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Renova automaticamente a cada %@ a menos que seja cancelado pelo menos 24h antes do fim do período. Cobrado no seu Apple ID. Gerir nas Definições."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Se reînnoiește automat la fiecare %@ dacă nu este anulat cu cel puțin 24h înainte de sfârșitul perioadei. Facturat pe Apple ID-ul tău. Gestionează în Setări."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Автоматически продлевается каждые %@, если не отменено за 24 часа до окончания периода. Оплата через ваш Apple ID. Управление в Настройках."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Automaticky sa obnovuje každých %@, pokiaľ nie je zrušené aspoň 24 hodín pred koncom obdobia. Účtované na váš Apple ID. Spravujte v Nastaveniach."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Samodejno se obnavlja vsak %@, razen če je preklicano vsaj 24 ur pred koncem obdobja. Zaračunano na vaš Apple ID. Upravljajte v nastavitvah."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Аутоматски се обнавља сваких %@ осим ако се не откаже најмање 24 сата пре краја периода. Наплаћује се на ваш Apple ID. Управљајте у Подешавањима."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Förnyas automatiskt var %@ om det inte avbryts minst 24 timmar före periodens slut. Faktureras till ditt Apple-ID. Hantera i Inställningar."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Inajifanya upya kila %@ isipokuwa ikighairiwa angalau saa 24 kabla ya muda kumalizika. Inatozwa kwa Apple ID yako. Simamia katika Mipangilio."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "ஒவ்வொரு %@ தானாக புதுப்பிக்கப்படும், காலம் முடிவதற்கு குறைந்தது 24 மணி நேரத்திற்கு முன் ரத்து செய்யப்படாவிட்டால். உங்கள் Apple ID-க்கு பில் செய்யப்படும். அமைப்புகளில் நிர்வகிக்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "ప్రతి %@ ఆటో-రెన్యూ అవుతుంది, వ్యవధి ముగియడానికి కనీసం 24 గంటల ముందు రద్దు చేయకపోతే. మీ Apple IDకి బిల్ చేయబడుతుంది. సెట్టింగ్‌లలో నిర్వహించండి."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ต่ออายุอัตโนมัติทุก %@ เว้นแต่จะยกเลิกก่อนสิ้นสุดระยะเวลาอย่างน้อย 24 ชม. เรียกเก็บเงินจาก Apple ID ของคุณ จัดการในการตั้งค่า"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dönem sona ermeden en az 24 saat önce iptal edilmedikçe her %@ otomatik yenilenir. Apple Kimliğinize faturalandırılır. Ayarlardan yönetin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Автоматично поновлюється кожні %@, якщо не скасовано принаймні за 24 години до закінчення періоду. Оплата через ваш Apple ID. Керуйте в Налаштуваннях."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tự động gia hạn mỗi %@ trừ khi hủy ít nhất 24 giờ trước khi hết hạn. Tính phí vào Apple ID của bạn. Quản lý trong Cài đặt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每%@自动续订，除非在到期前至少24小时取消。费用将从您的Apple ID扣除。在设置中管理。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "每%@自動續訂，除非在到期前至少24小時取消。費用將從您的Apple ID扣除。在設定中管理。"
          }
        }
      }
