    "Restore failed. Please try again.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل الاستعادة. يرجى المحاولة مرة أخرى."
          }
        },
        "bg": {
          "stringUnit": {
            "state": "translated",
            "value": "Възстановяването не бе успешно. Моля, опитайте отново."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "পুনরুদ্ধার ব্যর্থ হয়েছে। অনুগ্রহ করে আবার চেষ্টা করুন।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La restauració ha fallat. Torna-ho a provar."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Obnovení se nezdařilo. Zkuste to prosím znovu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Gendannelse mislykkedes. Prøv venligst igen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wiederherstellung fehlgeschlagen. Bitte versuche es erneut."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η επαναφορά απέτυχε. Παρακαλώ δοκιμάστε ξανά."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Restore failed. Please try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error al restaurar. Por favor, inténtalo de nuevo."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Taastamine ebaõnnestus. Palun proovi uuesti."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Palautus epäonnistui. Yritä uudelleen."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Hindi matagumpay ang pag-restore. Pakisubukan muli."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La restauration a échoué. Veuillez réessayer."
          }
        },
        "gu": {
          "stringUnit": {
            "state": "translated",
            "value": "પુનઃસ્થાપન નિષ્ફળ. કૃપા કરીને ફરીથી પ્રયાસ કરો."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "השחזור נכשל. אנא נסה שוב."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पुनर्स्थापना विफल. कृपया पुनः प्रयास करें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Obnavljanje nije uspjelo. Pokušajte ponovo."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A visszaállítás sikertelen. Kérjük, próbáld újra."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pemulihan gagal. Silakan coba lagi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ripristino non riuscito. Riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "復元に失敗しました。もう一度お試しください。"
          }
        },
        "kn": {
          "stringUnit": {
            "state": "translated",
            "value": "ಮರುಸ್ಥಾಪನೆ ವಿಫಲವಾಗಿದೆ. ದಯವಿಟ್ಟು ಮತ್ತೆ ಪ್ರಯತ್ನಿಸಿ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "복원에 실패했습니다. 다시 시도해 주세요."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Atkūrimas nepavyko. Bandykite dar kartą."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Atjaunošana neizdevās. Lūdzu, mēģiniet vēlreiz."
          }
        },
        "ml": {
          "stringUnit": {
            "state": "translated",
            "value": "പുനഃസ്ഥാപിക്കൽ പരാജയപ്പെട്ടു. ദയവായി വീണ്ടും ശ്രമിക്കുക."
          }
        },
        "mr": {
          "stringUnit": {
            "state": "translated",
            "value": "पुनर्संचयन अयशस्वी. कृपया पुन्हा प्रयत्न करा."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pemulihan gagal. Sila cuba lagi."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Gjenoppretting mislyktes. Vennligst prøv igjen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Herstel mislukt. Probeer het opnieuw."
          }
        },
        "pa": {
          "stringUnit": {
            "state": "translated",
            "value": "ਰੀਸਟੋਰ ਅਸਫਲ। ਕਿਰਪਾ ਕਰਕੇ ਦੁਬਾਰਾ ਕੋਸ਼ਿਸ਼ ਕਰੋ।"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przywracanie nie powiodło się. Spróbuj ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao restaurar. Tente novamente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Restauro falhou. Tente novamente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Restaurarea a eșuat. Vă rugăm să încercați din nou."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось восстановить. Пожалуйста, попробуйте снова."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Obnovenie zlyhalo. Skúste to znova."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Obnovitev ni uspela. Poskusite znova."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Враћање није успело. Покушајте поново."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Återställning misslyckades. Försök igen."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Urejeshaji umeshindwa. Tafadhali jaribu tena."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "மீட்டமைப்பு தோல்வியடைந்தது. மீண்டும் முயற்சிக்கவும்."
          }
        },
        "te": {
          "stringUnit": {
            "state": "translated",
            "value": "పునరుద్ధరణ విఫలమైంది. దయచేసి మళ్ళీ ప్రయత్నించండి."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การกู้คืนล้มเหลว กรุณาลองอีกครั้ง"
